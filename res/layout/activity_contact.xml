<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/header_main"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_above="@+id/bt_addcart">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="10dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_gravity="center"
                            android:src="@drawable/helpdesk"
                            android:layout_width="90dp"
                            android:layout_height="90dp"/>

                        <TextView
                            android:fontFamily="@font/custom_font"
                            android:textAlignment="center"
                            android:textSize="16dp"
                            android:layout_marginTop="25dp"
                            android:textColor="@color/black"
                            android:text="Have questions or need assistance?"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:fontFamily="@font/custom_font"
                            android:textAlignment="center"
                            android:textSize="14dp"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/black"
                            android:text="Have questions or need assistance? We’re here to help! Reach out to our support team for any inquiries, feedback, or technical support. Your satisfaction is our priority."
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <LinearLayout
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="center"
                                android:layout_margin="5dp"
                                android:text="Email:"
                                android:textStyle="bold"
                                android:textSize="16dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:textSize="16dp"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="textStart"
                                android:layout_margin="5dp"
                                android:text="info@adlsaurav.com"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>
                        <LinearLayout
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:layout_marginTop="0dp"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="center"
                                android:layout_margin="5dp"
                                android:text="Mobile:"
                                android:textStyle="bold"
                                android:textSize="16dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:textSize="16dp"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="textStart"
                                android:layout_margin="5dp"
                                android:text="+91-8936821111"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <Button
                                android:id="@+id/btncall"
                                android:textColor="@color/white"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="center"
                                android:layout_margin="5dp"
                                android:text="CALL NOW"
                                android:background="@drawable/round_button"
                                android:textStyle="bold"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:textSize="14dp"
                                android:layout_width="120dp"
                                android:layout_height="40dp"/>

                            <Button
                                android:id="@+id/btnwhtsapp"
                                android:textSize="14dp"
                                android:background="@drawable/round_button_blue"
                                android:textColor="@color/white"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="center"
                                android:layout_margin="5dp"
                                android:text="WHATSAPP"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:layout_width="120dp"
                                android:layout_height="40dp"/>

                        </LinearLayout>
                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>
            </LinearLayout>
        </RelativeLayout>

    </LinearLayout>


</LinearLayout>