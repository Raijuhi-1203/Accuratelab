<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background Color -->
    <solid android:color="@color/blue"/>

    <!-- Corner Radius -->
    <corners android:radius="25dp"/>

    <!-- Optional Border -->
    <stroke
        android:width="2dp"
        android:color="@color/blue"/>

    <!-- Optional Padding -->
    <padding
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="8dp"/>

</shape>
